# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
DP_FRONTEND_URL=http://localhost:5174
ADMIN_FRONTEND_URL=http://localhost:5175

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/groceries

# MongoDB
MONGODB_URI=mongodb://localhost:27017/groceries

# Redis (optional for cart/session caching)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# Cookie
COOKIE_SECRET=your_cookie_secret_change_in_production
